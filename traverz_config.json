{
  "providers": {
    "gemini": {
      "apiKey": "${GEMINI_API_KEY}",
      "apiBase": "https://generativelanguage.googleapis.com/v1beta/openai/"
    }
  },
  "agents": {
    "defaults": {
      "model": "gemini-2.5-flash",
      "provider": "gemini",
      "maxTokens": 8192,
      "contextWindowTokens": 131072,
      "temperature": 0.3,
      "maxToolIterations": 50,
      "timezone": "Asia/Singapore",
      "unifiedSession": false,
      "sessionTtlMinutes": 0,
      "disabledSkills": ["github", "tmux", "clawhub", "skill-creator"],
      "workspace": "/tmp/workspace"
    }
  },
  "tools": {
    "exec": {
      "enable": false
    },
    "web": {
      "enable": true,
      "search": {
        "provider": "duckduckgo",
        "maxResults": 5
      }
    },
    "restrictToWorkspace": true
  },
  "gateway": {
    "host": "0.0.0.0",
    "port": 9090
  },
  "channels": {
    "websocket": {
      "enabled": true,
      "host": "0.0.0.0",
      "port": 8080,
      "path": "/ws",
      "token": "${WEBSOCKET_TOKEN_SECRET}",
      "tokenIssuePath": "/ws-token",
      "tokenIssueSecret": "${WEBSOCKET_TOKEN_SECRET}",
      "websocketRequiresToken": true,
      "streaming": true
    },
    "whatsapp": {
      "enabled": false
    },
    "telegram": {
      "enabled": false
    }
  }
}
